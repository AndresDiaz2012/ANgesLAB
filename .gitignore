# ============================================================
# ANgesLAB v2.0 - .gitignore
# Sistema de Gestión de Laboratorio Clínico
# ============================================================

# ----- Base de datos (datos clínicos protegidos) --------------
*.accdb
*.accdb.bak
*.laccdb
*.ldb
*.mdb

# ----- Configuración local (credenciales / rutas) -------------
config_ia.json
db_config.json
backup_config.json

# ----- Directorios de datos en tiempo de ejecución ------------
backups/
logs/
firmas/

# ----- Instalador compilado -----------------------------------
instalador/output/

# ----- Python bytecode ----------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# ----- IDE / Editor -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.claude/

# ----- Sistema operativo --------------------------------------
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db

# ----- Temporales ---------------------------------------------
*.tmp
*.bak
*.log
nul
