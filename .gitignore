# ============================================================
# ANgesLAB - Sistema de Gestión de Laboratorio Clínico
# .gitignore
# ============================================================

# ----- Base de datos (contiene datos clínicos protegidos) ----
*.accdb
*.laccdb
*.ldb

# ----- Configuración local (credenciales / rutas) -----------
config_ia.json
db_config.json
backup_config.json

# ----- Directorios de datos en tiempo de ejecución ----------
backups/
logs/
firmas/

# ----- Python bytecode --------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# ----- IDE / Editor -----------------------------------------
.vscode/
.idea/
*.swp
*.swo
.claude/

# ----- Sistema operativo ------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# ----- Temporales -------------------------------------------
*.tmp
*.bak
nul
